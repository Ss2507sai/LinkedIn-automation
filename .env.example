# Browser connection (Chrome 149+ requires non-default user-data-dir for CDP)
CDP_URL=http://127.0.0.1:9222
CHROME_USER_DATA_DIR=/Users/YOUR_USERNAME/Library/Application Support/Google/ChromeForAutomation
CHROME_PROFILE_DIRECTORY=Default
CHROME_AUTOMATION_PROFILE_DIR=.chrome-automation-profile
BROWSER_CHANNEL=chrome
HEADLESS=false

# Timing (seconds)
DELAY_MIN=1.0
DELAY_MAX=3.0
PAGE_LOAD_TIMEOUT_MS=60000
CHATGPT_RESPONSE_TIMEOUT_SEC=180
CHATGPT_STABILITY_CHECKS=3
CHATGPT_STABILITY_INTERVAL_SEC=2.0

# Retries
RETRY_COUNT=1
MAX_PAGINATION_RETRIES=3

# Mode (prefer CLI: --limit 1, --limit 3, --full)
TEST_MODE=false
TEST_MODE_LIMIT=3
APPROVAL_MODE=false
CONNECT_DRY_RUN=false

# Tab URL patterns
SALES_NAV_URL_PATTERN=linkedin.com/sales
CHATGPT_URL_PATTERN=chatgpt.com

# Output paths
RESULTS_XLSX=results.xlsx
RESULTS_CSV=results.csv
PROCESSED_PROFILES_JSON=processed_profiles.json
LOGS_DIR=logs
SCREENSHOTS_DIR=screenshots
LOG_FILE=logs/automation.log
